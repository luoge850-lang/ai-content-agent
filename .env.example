# ── AI Content Agent — Environment Variables ────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to git — it's in .gitignore.

# ── App ──────────────────────────────────────────────────
APP_NAME="AI Content Agent API"
APP_ENV=development
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
FRONTEND_BASE_URL=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────
# Used by Next.js to locate the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Database ─────────────────────────────────────────────
# Dev (SQLite):  sqlite+aiosqlite:///./ai_content_agent.db
# Prod (PG):     postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./ai_content_agent.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── AI Provider (DeepSeek / OpenAI-compatible) ───────────
# Get a free key at https://platform.deepseek.com/
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_DAILY_LIMIT=50

# ── Email / SMTP (Resend, SendGrid, Mailgun, etc.) ──────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aicontentagent.local
SMTP_USE_TLS=true
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=60

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_IP=5/minute
RATE_LIMIT_LOGIN_EMAIL=3/minute
RATE_LIMIT_REGISTER_IP=5/hour
RATE_LIMIT_RESEND_EMAIL=1/minute;5/day
RATE_LIMIT_AI_USER=50/day
RATE_LIMIT_UPLOAD=20/hour

# ── Security ─────────────────────────────────────────────
TRUSTED_PROXIES=127.0.0.1,::1

# ── Docker ───────────────────────────────────────────────
POSTGRES_USER=aiagent
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=ai_content_agent
REDIS_PASSWORD=change-this-redis-password
WEB_CONCURRENCY=4
CELERY_CONCURRENCY=4
